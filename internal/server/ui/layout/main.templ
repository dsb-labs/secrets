package layout

templ Main(title string, view templ.Component) {
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ title }</title>
		</head>
		<body>
            <main>
                @view
            </main>
		</body>
	</html>
}
